# PersonaLingo .skillignore
# 兜底排除清单：阻止 skills CLI 把项目代码也复制到 agent 的 .agents/skills 目录。
# 若 CLI 识别了 skill.json 的 files 白名单，此文件仅作双保险。

# Project source trees (only needed for runnable-export mode, not install-only)
backend/
frontend/
docs/
tests/
tools/

# Build artifacts & local caches
dist/
build/
node_modules/
.venv/
__pycache__/

# CI / IDE / misc
.github/
.qoder/
.trae/
.vscode/
.idea/

# Docker & server configs (belong to runnable-export, not install-only)
docker-compose.yml
Dockerfile
start.bat
start.ps1

# Exported skill packs (huge, runnable-export only)
skills/runnable/

# Debug outputs & logs
*.log
*.err.log
*.out.log
backend_pid.txt
frontend_pid.txt
tmp_review_diff.txt

# Secrets / env
.env
.env.*
!.env.example

# Screenshots & binary assets unrelated to install-only
screenshots_verify/
docs/screenshots/
