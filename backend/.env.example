# LLM Provider: openai or anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database
DB_PATH=app/data/personalingo.db

# Server
HOST=0.0.0.0
PORT=9849

# App
APP_NAME=PersonaLingo
DEBUG=false

# IELTS Target Score (default band for questionnaire fallback)
TARGET_SCORE=7.0

# CORS: comma-separated list of allowed frontend origins (leave empty to use defaults)
# Example: CORS_ALLOW_ORIGINS=http://localhost:5273,http://127.0.0.1:5273
CORS_ALLOW_ORIGINS=

# ---------- Web Search (题库动态更新 / 深度调研) ----------
# Provider id: tavily | exa | examcp | bocha | zhipu | querit | searxng | google | bing | baidu
SEARCH_PROVIDER=
SEARCH_API_KEY=
# searxng / examcp 等自部署场景填写
SEARCH_BASE_URL=
# 搜索通用选项
SEARCH_INCLUDE_DATE=true
SEARCH_MAX_RESULTS=20
# 搜索结果压缩: rag | truncate | none
SEARCH_COMPRESSION=rag
SEARCH_CHUNK_COUNT=3
# QMD 可选增强（留空时自动回退到 BM25+TF-IDF 本地实现）
SEARCH_EMBEDDING_MODEL=
SEARCH_EMBEDDING_DIM=0
SEARCH_RERANKER_MODEL=

# ---------- Distill Pipeline ----------
# Stage 1 研究阶段是否调用 web_search 做深度调研（默认关闭）
DISTILL_RESEARCH_WEB_SEARCH=false

# ---------- Skill Runnable Output ----------
# 可运行 Skill 包输出根路径；留空则默认为 <repo>/skills/runnable/
SKILL_RUNNABLE_OUT_ROOT=
